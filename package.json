{
  "name": "threadline",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "browser": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "bun run scripts/build.ts",
    "clean": "bun run scripts/clean.ts",
    "dev": "bun --watch run src/index.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "test": "bun test index.test features.test",
    "test:browser": "concurrently \"bun run test:server\" \"playwright test\" --kill-others --success first",
    "test:browser:debug": "concurrently \"bun run test:server\" \"playwright test --debug\" --kill-others --success first",
    "test:browser:headed": "concurrently \"bun run test:server\" \"playwright test --headed\" --kill-others --success first",
    "test:browser:ui": "concurrently \"bun run test:server\" \"playwright test --ui\" --kill-others --success first",
    "test:coverage": "bun test --coverage",
    "test:parallel": "bun test --parallel",
    "test:server": "bun run tests/end-to-end/server.ts",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit"
  },
  "lint-staged": {
    "src/**/*.{js,ts,tsx,jsx,mjs,cjs}": [
      "eslint --fix"
    ],
    "scripts/**/*.{js,ts,tsx,jsx,mjs,cjs}": [
      "eslint --fix"
    ],
    "*.{json,md,css,scss}": [
      "prettier --write"
    ],
    "package.json": [
      "sort-package-json"
    ]
  },
  "dependencies": {
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.4.1",
    "@playwright/test": "^1.53.2",
    "@types/bun": "^1.2.13",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "concurrently": "^9.2.0",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-unicorn": "^59.0.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^16.1.0",
    "happy-dom": "^18.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "playwright": "^1.53.2",
    "prettier": "^3.5.3",
    "sort-package-json": "^3.2.1"
  },
  "engines": {
    "bun": ">=1.13.0"
  }
}
